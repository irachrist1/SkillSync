{
  "name": "skillsync-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json",
    "convex:dev": "convex dev",
    "convex:codegen": "convex dev --once --typecheck=disable",
    "data:validate": "node scripts/data/validate-curated.mjs",
    "data:import": "node scripts/data/import-curated.mjs",
    "data:import-careers": "tsx scripts/import-careers.ts",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "ci": "npm run lint && npm run type-check && npm run test && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.28.4",
    "lucide-react": "^0.294.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-plugin-playwright": "^2.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "description": "Rwanda Skills-to-Jobs Matcher with AI-powered career analysis",
  "keywords": [
    "rwanda",
    "jobs",
    "skills",
    "career",
    "ai",
    "matching",
    "next.js",
    "typescript"
  ],
  "author": "SkillSync Team",
  "license": "MIT"
}
